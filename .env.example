# Qobuzarr Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# QOBUZ API CREDENTIALS (REQUIRED)
# =============================================================================
# You must obtain these from Qobuz or through legitimate means
# DO NOT commit real credentials to version control

# Qobuz Application ID 
QOBUZ_APP_ID=your_app_id_here

# Qobuz Application Secret
QOBUZ_APP_SECRET=your_app_secret_here

# =============================================================================
# QOBUZ USER CREDENTIALS (CHOOSE ONE METHOD)
# =============================================================================

# Method 1: Email/Password Authentication
QOBUZ_EMAIL=your_email@example.com
QOBUZ_PASSWORD=your_password_here

# Method 2: Token-based Authentication (if you have existing tokens)
# QOBUZ_USER_ID=your_user_id
# QOBUZ_AUTH_TOKEN=your_auth_token

# =============================================================================
# AUDIO QUALITY SETTINGS
# =============================================================================
# Quality levels:
# 5  = MP3 320kbps
# 6  = FLAC CD Quality (16-bit/44.1kHz)
# 7  = FLAC Hi-Res (up to 24-bit/96kHz)
# 27 = FLAC Maximum Available Quality
QOBUZ_QUALITY=27

# =============================================================================
# DOWNLOAD SETTINGS
# =============================================================================
# Base directory for downloads
QOBUZ_DOWNLOAD_PATH=./Downloads

# Maximum concurrent downloads (1-10)
QOBUZ_MAX_CONCURRENT_DOWNLOADS=3

# =============================================================================
# LIDARR INTEGRATION (OPTIONAL - for CLI testing)
# =============================================================================
# Lidarr instance URL (for CLI integration testing)
LIDARR_URL=http://localhost:8686

# Lidarr API Key (for CLI integration testing)
LIDARR_API_KEY=your_lidarr_api_key_here

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Log level (Debug, Info, Warn, Error)
LOG_LEVEL=Info

# Cache directory
CACHE_DIRECTORY=./cache

# Enable debug output
DEBUG_MODE=false