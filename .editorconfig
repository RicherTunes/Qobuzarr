root = true

# C#
[*.cs]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

# Analyzer severity baseline (tighten over time)
dotnet_analyzer_diagnostic.severity = warning

# Nullable/reference types
dotnet_diagnostic.CS8618.severity = warning
dotnet_diagnostic.CS8602.severity = warning

# Style preferences
dotnet_style_qualification_for_field = true:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

# Using directives
csharp_using_directive_placement = outside_namespace:silent

# New line options
csharp_new_line_before_members = true

# File headers are not required
file_header_template = none
dotnet_diagnostic.IDE0073.severity = none

# Namespace style - allow file-scoped namespaces
dotnet_diagnostic.IDE0130.severity = none
dotnet_diagnostic.IDE0160.severity = none

# Code style preferences - relaxed for flexibility
dotnet_diagnostic.IDE0011.severity = suggestion
dotnet_diagnostic.IDE0270.severity = suggestion
dotnet_diagnostic.IDE0005.severity = warning

# Allow SCREAMING_CASE constants (API-driven naming)
dotnet_diagnostic.CA1707.severity = none

# Allow lowercase DTO properties (JSON serialization naming)
dotnet_naming_rule.public_members_should_be_capitalized.severity = none
dotnet_diagnostic.IDE1006.severity = none

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# XML/csproj files
[*.{xml,csproj,props,targets}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Unused code analysis - warnings for CLI/test mock code flexibility
dotnet_diagnostic.IDE0052.severity = suggestion  # Private member unused
dotnet_diagnostic.IDE0060.severity = suggestion  # Unused parameter

# Generated regex suggestion (allow runtime regex in tests)
dotnet_diagnostic.SYSLIB1045.severity = suggestion

# Collection expression preference - allow both styles
dotnet_diagnostic.IDE0305.severity = suggestion
