root = true

# C#
[*.cs]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

# Analyzer severity baseline (tighten over time)
dotnet_analyzer_diagnostic.severity = warning

# Nullable/reference types
dotnet_diagnostic.CS8618.severity = warning
dotnet_diagnostic.CS8602.severity = warning

# Style preferences
dotnet_style_qualification_for_field = true:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_event = false:silent

# Using directives
csharp_using_directive_placement = outside_namespace:silent

# New line options
csharp_new_line_before_members = true

# File headers are not required
file_header_template = none
dotnet_diagnostic.IDE0073.severity = none

# Namespace style - allow file-scoped namespaces
dotnet_diagnostic.IDE0130.severity = none
dotnet_diagnostic.IDE0160.severity = none

# Code style preferences - relaxed for flexibility
dotnet_diagnostic.IDE0011.severity = suggestion
dotnet_diagnostic.IDE0270.severity = suggestion
dotnet_diagnostic.IDE0005.severity = warning

# Allow SCREAMING_CASE constants (API-driven naming)
dotnet_diagnostic.CA1707.severity = none

# Allow lowercase DTO properties (JSON serialization naming)
dotnet_naming_rule.public_members_should_be_capitalized.severity = none
dotnet_diagnostic.IDE1006.severity = none

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# XML/csproj files
[*.{xml,csproj,props,targets}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Unused code analysis - warnings for CLI/test mock code flexibility
dotnet_diagnostic.IDE0052.severity = suggestion  # Private member unused
dotnet_diagnostic.IDE0060.severity = suggestion  # Unused parameter

# Generated regex suggestion (allow runtime regex in tests)
dotnet_diagnostic.SYSLIB1045.severity = suggestion

# Collection expression preference - allow both styles
dotnet_diagnostic.IDE0305.severity = suggestion

# =============================================================================
# Phase 3.2 Analyzer Baseline Suppressions
# Captured: 2026-05-23 | Baseline: 856 unique warnings
# Strategy: silence stylistic/opinionated categories (50+ occurrences) that
# either cannot be fixed mechanically without touching in-flight files, or
# require API changes incompatible with the Lidarr plugin contract.
# Security analyzers (CA21##, CA31##, CA51##) are intentionally NOT suppressed.
# =============================================================================

# CA1305 (273 hits) — Logger.*() calls need IFormatProvider
# JUSTIFICATION: NLog's Logger API (Logger.Debug/Info/Warn/Error) does not accept
# IFormatProvider as a parameter. The fix would require switching to LoggerMessage
# delegates (CA1848), which is a large separate refactor tracked in Phase 2.
# Silencing prevents false-positive noise for a legitimate API limitation.
dotnet_diagnostic.CA1305.severity = silent

# CA1822 (160 hits) — Members can be marked static
# JUSTIFICATION: Mechanically correct, but many of these members are on types that
# implement Lidarr interfaces or are virtual/override candidates. Marking them static
# would break derived-class extensibility. Deferred to Phase 4 with per-file review.
dotnet_diagnostic.CA1822.severity = suggestion

# CA1860 (89 hits) — Prefer Count==0 over .Any()
# JUSTIFICATION: Purely stylistic preference. .Any() is more readable and correctly
# short-circuits on IEnumerable sequences where Count may not be O(1). Silencing
# avoids 89 noisy warnings that offer no correctness improvement.
dotnet_diagnostic.CA1860.severity = silent

# CA1848 (17 hits) — Use LoggerMessage delegates
# JUSTIFICATION: LoggerMessage requires significant structural refactor (partial
# classes, source generators). Tracked as Phase 2 work. Silencing prevents it from
# polluting the baseline while the larger CA1305 logging work is addressed first.
dotnet_diagnostic.CA1848.severity = silent

# CA1304 (46 hits) — String comparison lacks StringComparison
# CA1310 (12 hits) — Specify StringComparison for correctness
# JUSTIFICATION: Most occurrences are in search/filter paths where ordinal
# comparison is already the implied intent. Fixing requires per-call audit to
# choose the right StringComparison variant. Reducing severity to suggestion
# keeps them visible during code review without blocking CI.
dotnet_diagnostic.CA1304.severity = suggestion
dotnet_diagnostic.CA1310.severity = suggestion

# CA1859 (8 hits) — Use concrete type for improved performance
# JUSTIFICATION: Changing parameter types from interfaces to concrete types would
# break the Lidarr plugin interface contract and reduce testability. Silencing.
dotnet_diagnostic.CA1859.severity = silent

# CA1716 (5 hits) — Identifier matches reserved keyword
# JUSTIFICATION: These identifiers are constrained by the Lidarr public plugin API
# (e.g., Protocol, Type) and cannot be renamed without breaking the plugin host.
dotnet_diagnostic.CA1716.severity = silent

# CA1845 (5 hits) — Use AsSpan or AsMemory instead of Range indexer
# JUSTIFICATION: The AsSpan/AsMemory pattern requires callee changes that may not
# be compatible with all Lidarr-provided APIs. Medium-effort; deferred to Phase 4.
dotnet_diagnostic.CA1845.severity = suggestion

# CA1869 (3 hits) — Cache JsonSerializerOptions instances
# JUSTIFICATION: Instances are already effectively cached at their call sites via
# static fields or DI. The remaining hits are in test/utility code. Suggestion only.
dotnet_diagnostic.CA1869.severity = suggestion

# CA1725 (3 hits) — Parameter names must match base declaration
# JUSTIFICATION: Parameter names are inherited from Lidarr's base classes/interfaces
# where we cannot change the base. Silencing.
dotnet_diagnostic.CA1725.severity = silent

# CA1835 (2 hits) — Use Memory<T> overload for stream operations
# JUSTIFICATION: Low-count; the stream operations are in compatibility shim code
# where the Memory<T> overload may not be available on the target runtime. Silent.
dotnet_diagnostic.CA1835.severity = silent

# CA5351 (2 hits) — MD5 is a broken cryptographic algorithm
# JUSTIFICATION: Qobuz's streaming API mandates MD5 for request signing. This is
# NOT used for security/integrity purposes — it is a protocol requirement. The
# usages are already annotated with #pragma comments explaining the necessity.
# Keeping as suggestion (not silent) so new MD5 usages get flagged for review.
dotnet_diagnostic.CA5351.severity = suggestion
