<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Lidarr.Plugin.Common</id>
    <version>1.0.0</version>
    <title>Lidarr Plugin Common Library</title>
    <authors>RicherTunes</authors>
    <owners>RicherTunes</owners>
    <description>
      Shared library for building Lidarr streaming service plugins. 
      Provides utilities, models, and patterns that reduce development time by 40-60%.
      Includes file naming, HTTP utilities, retry logic, quality management, and testing support.
    </description>
    <releaseNotes>
      v1.0.0: Initial release with core utilities and models
      - FileNameSanitizer for cross-platform file naming
      - HttpClientExtensions with retry logic and security
      - RetryUtilities with circuit breaker and rate limiting  
      - Universal streaming models (Artist, Album, Track, Quality)
      - Quality mapping and comparison utilities
      - Testing support with mock factories
      - Performance monitoring utilities
      - Lidarr integration helpers
    </releaseNotes>
    <summary>
      Shared utilities and models for Lidarr streaming service plugin development.
    </summary>
    <language>en-US</language>
    <projectUrl>https://github.com/RicherTunes/Qobuzarr</projectUrl>
    <iconUrl>https://github.com/RicherTunes/Qobuzarr/raw/main/docs/assets/logo.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <copyright>Copyright © 2025 RicherTunes</copyright>
    <tags>lidarr plugin streaming music qobuz tidal spotify utilities</tags>
    <repository type="git" url="https://github.com/RicherTunes/Qobuzarr.git" branch="main" commit="" />
    
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="System.Text.Json" version="6.0.0" />
      </group>
    </dependencies>
  </metadata>
  
  <files>
    <!-- Main assembly -->
    <file src="bin\Release\net6.0\Lidarr.Plugin.Common.dll" target="lib\net6.0\Lidarr.Plugin.Common.dll" />
    <file src="bin\Release\net6.0\Lidarr.Plugin.Common.pdb" target="lib\net6.0\Lidarr.Plugin.Common.pdb" />
    <file src="bin\Release\net6.0\Lidarr.Plugin.Common.xml" target="lib\net6.0\Lidarr.Plugin.Common.xml" />
    
    <!-- Source files for debugging -->
    <file src="**\*.cs" target="src" exclude="bin\**;obj\**" />
    
    <!-- Documentation -->
    <file src="README.md" target="README.md" />
    <file src="CHANGELOG.md" target="CHANGELOG.md" />
    
    <!-- Examples and templates -->
    <file src="..\examples\**\*.cs" target="examples" />
    <file src="..\examples\**\*.md" target="examples" />
  </files>
</package>