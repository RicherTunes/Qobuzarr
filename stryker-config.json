{
  "stryker-config": {
    "project": "Qobuzarr.csproj",
    "test-projects": [
      "tests/Qobuzarr.Tests/Qobuzarr.Tests.csproj"
    ],
    "reporters": [
      "html",
      "json",
      "console"
    ],
    "html-reporter": {
      "output-folder": "mutation-report"
    },
    "thresholds": {
      "high": 85,
      "low": 70,
      "break": 60
    },
    "thresholds-per-module": {
      "src/Services/Observability/**": {
        "high": 95,
        "low": 85,
        "break": 80
      },
      "src/Services/Consolidated/**": {
        "high": 90,
        "low": 80,
        "break": 75
      },
      "src/API/**": {
        "high": 85,
        "low": 70,
        "break": 65
      }
    },
    "mutate": [
      "src/Services/**/*.cs",
      "src/API/**/*.cs",
      "src/Download/**/*.cs",
      "src/Indexers/**/*.cs",
      "src/Services/Observability/**/*.cs"
    ],
    "ignore-mutations": [
      "Logging statements",
      "Exception messages"
    ],
    "exclude-mutations": [
      "src/Constants/**",
      "src/Models/**",
      "src/Integration/**"
    ],
    "timeout-ms": 10000,
    "max-concurrent-test-runners": 4,
    "mutation-level": "Standard"
  }
}