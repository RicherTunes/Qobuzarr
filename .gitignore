# =============================================================================
# Qobuzarr Plugin - Comprehensive .gitignore
# =============================================================================

# Build results and artifacts
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
build/
_output/
_temp/

# Visual Studio cache/options directory
.vs/
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# JetBrains Rider
.idea/

# Test results and coverage
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResults/
coverage-report/
*.cobertura.xml
opencover.xml
coverage.json
*.trx

# Cache and temporary directories
**/cache/
**/temp/
**/tmp/
**/benchmark-results/
**/performance-test-results/
**/stress-test-output/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
# KEEP ext/Lidarr-source/ LOCALLY BUT EXCLUDE FROM GIT
# =============================================================================
ext/Lidarr-source/
ext/Lidarr/

# Exclude downloaded Lidarr assemblies (pre-built dependencies)
Lidarr/
lidarr-assemblies/
lidarr-download/

# But keep the README explaining the requirement
!ext/README.md

# =============================================================================
# Log files and debug output
# =============================================================================
*.log
*.tmp
*.bak
nul
build_output.txt
build_errors.log
*.pid
*.lock
dependency-check-report.html
security-scan-results.json

# =============================================================================
# Development and configuration files
# =============================================================================
appsettings.Development.json
*.Development.json

# Environment files with sensitive data
.env
*.env
.env.*
!.env.example
!.env.template

# =============================================================================
# Audio files (copyrighted content - never commit)
# =============================================================================
*.flac
*.mp3
*.wav
*.m4a
*.aac
*.wma
*.ogg

# =============================================================================
# CLI-specific exclusions
# =============================================================================
QobuzCLI/Downloads/
QobuzCLI/test-downloads/
QobuzCLI/TestDownloads/
QobuzCLI/metadata-test*/
QobuzCLI/sample-queries.txt
QobuzCLI/qobuz-credentials.cache
QobuzCLI/dashboard_*
QobuzCLI/*.html
QobuzCLI/*.png
QobuzCLI/*.jpg
QobuzCLI/*.jpeg
QobuzCLI/**/cover.jpg
QobuzCLI/**/folder.jpg

# CLI test artifacts
QobuzCLI/test-*
QobuzCLI/*test*
QobuzCLI/*-test.txt
QobuzCLI/build.log
QobuzCLI/output.log
QobuzCLI/fresh-*.txt
QobuzCLI/simple-*.txt
QobuzCLI/single-*.txt
QobuzCLI/dashboard-test.txt
QobuzCLI/metadata-test.txt
QobuzCLI/bach-test.txt

# CLI scripts and commands
QobuzCLI/*.ps1
QobuzCLI/run_*.bat
QobuzCLI/*.cmd
QobuzCLI/take_screenshot.ps1
QobuzCLI/run-*.ps1
QobuzCLI/check-*.ps1

# =============================================================================
# Large data files and exports
# =============================================================================
# Note: Avoid blanket *.json exclusion to preserve important config files

# Specifically exclude large data files
QobuzCLI/all.json
QobuzCLI/real_albums_data.json
QobuzCLI/test-export-*.json
QobuzCLI/lidarr-wanted-albums-*.json
QobuzCLI/wanted-albums.json
QobuzCLI/baseline-performance.json
QobuzCLI/concurrency-test-results.json
QobuzCLI/test-history.json
scripts/*.json
scripts/*.txt

# =============================================================================
# Test directories and artifacts
# =============================================================================
test-*/
testDownloads*/
TestDownloads/

