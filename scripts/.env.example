# Qobuzarr Library Analysis Configuration
# Copy this file to .env and fill in your actual credentials

# Lidarr Instance Configuration
LIDARR_URL=http://192.168.2.50:8686
LIDARR_API_KEY=ca6a612bb8f84d9c976fcac967331da5

# Qobuz API Credentials (required for gap validation)
# Get these from: https://www.qobuz.com/apps/api
QOBUZ_APP_ID=your_qobuz_app_id_here
QOBUZ_APP_SECRET=your_qobuz_app_secret_here

# Qobuz User Authentication (choose ONE method)
# Method 1: Email/Password Authentication
QOBUZ_EMAIL=your@email.com
QOBUZ_PASSWORD=your_md5_hashed_password

# Method 2: Token Authentication (alternative to email/password)
QOBUZ_USER_ID=your_user_id_here
QOBUZ_USER_AUTH_TOKEN=your_user_auth_token_here

# Note: If both email and token auth are provided, email auth takes precedence
# The scripts will detect which method you've configured and use it automatically

# Analysis Configuration
DEFAULT_COMPLEXITY_THRESHOLD=0.4
DEFAULT_EXTRACTION_LIMIT=1000
DEFAULT_GAP_VALIDATION_LIMIT=50

# Output Configuration  
ANALYSIS_OUTPUT_DIR=scripts/analysis_results
GENERATED_TESTS_DIR=tests/Qobuzarr.Tests/Unit/Indexers