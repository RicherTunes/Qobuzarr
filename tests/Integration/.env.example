# Lidarr Configuration
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your_lidarr_api_key_here

# Docker Configuration (optional - for log monitoring)
DOCKER_CONTAINER_NAME=lidarr-container

# Test Configuration
MAX_CONCURRENT_DOWNLOADS=3
TEST_TIMEOUT_MINUTES=30
LOG_RETENTION_DAYS=7

# Qobuz Authentication (choose one method)
# Method 1: Username/Password
QOBUZ_USERNAME=your_qobuz_username
QOBUZ_PASSWORD=your_qobuz_password

# Method 2: User ID/Token (alternative to username/password)
# QOBUZ_USER_ID=your_user_id
# QOBUZ_USER_AUTH_TOKEN=your_auth_token

# App credentials (optional - defaults will be used if not specified)
# Default values are embedded in the codebase as fallback for users without their own credentials
# You can override with your own app credentials if you have them:
# QOBUZ_APP_ID=your_app_id_here
# QOBUZ_APP_SECRET=your_app_secret_here