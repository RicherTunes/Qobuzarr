<?xml version="1.0" encoding="utf-8"?>
<!--
  Full.runsettings - Complete test suite for nightly/release runs
  
  Usage: dotnet test (settings file: tests/Full.runsettings)
  
  Runs all tests (no category filter) with code coverage collection.
  Note: LiveIntegration tests still require ENABLE_LIVE_INTEGRATION_TESTS=true.
  BlameHangTimeout set to 120s for slower integration tests.
-->
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>TestResults</ResultsDirectory>
    <MaxCpuCount>0</MaxCpuCount>
    <TargetPlatform>x64</TargetPlatform>
    <!-- TargetFrameworkVersion intentionally omitted - let csproj decide -->
    <CollectSources>false</CollectSources>
    <!-- Session limit for the full suite (30 minutes). The suite's actual test work is
         under a minute total (~2345 tests, ~40s of execution); this is a generous backstop
         for the whole multi-project run plus coverage processing. The prior 7200000 (2h)
         value was a stopgap that let a non-exiting/deadlocked test host run for the full 2h
         before being aborted. The real defense is the active blame-hang collector: run-tests.ps1
         and ci.yml pass a "blame hang timeout" flag to dotnet test, which kills a stuck host in
         minutes (and captures a dump). A bare BlameHangTimeout element under RunConfiguration is
         INERT; it only takes effect when the blame collector is enabled via that command flag. -->
    <TestSessionTimeout>1800000</TestSessionTimeout>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <Workers>0</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
  <xunit>
    <MaxParallelThreads>0</MaxParallelThreads>
  </xunit>
  <!-- Enable coverage collection for nightly runs -->
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>[*Tests*]*,[*TestData*]*</Exclude>
          <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
          <ExcludeByFile>**/Migrations/**</ExcludeByFile>
          <SingleHit>false</SingleHit>
          <UseSourceLink>true</UseSourceLink>
          <IncludeTestAssembly>false</IncludeTestAssembly>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
  <!-- No TestCaseFilter here: full suite. Live tests still require ENABLE_LIVE_INTEGRATION_TESTS=true. -->
</RunSettings>
