<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>TestResults</ResultsDirectory>
    <MaxCpuCount>0</MaxCpuCount>
    <TargetPlatform>x64</TargetPlatform>
    <TargetFrameworkVersion>.NETCoreApp,Version=v6.0</TargetFrameworkVersion>
    <CollectSources>false</CollectSources>
    <TestSessionTimeout>900000</TestSessionTimeout>
    <BatchSize>0</BatchSize>
    <BlameHangTimeout>00:00:10</BlameHangTimeout>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <Workers>0</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
  <xunit>
    <MaxParallelThreads>0</MaxParallelThreads>
  </xunit>
  <RunConfiguration>
    <!-- Exclude long-running categories by default -->
    <TestCaseFilter>Category!=LiveIntegration&amp;Category!=Integration&amp;Category!=Performance&amp;Category!=Simulations</TestCaseFilter>
  </RunConfiguration>
</RunSettings>

