<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>TestResults</ResultsDirectory>
    <TargetPlatform>x64</TargetPlatform>
    <TargetFrameworkVersion>.NETCoreApp,Version=v6.0</TargetFrameworkVersion>
    <TestSessionTimeout>900000</TestSessionTimeout>
    <BatchSize>0</BatchSize>
    <BlameHangTimeout>00:00:10</BlameHangTimeout>
    <!-- Exclude slow/integration categories by default for fast runs -->
    <TestCaseFilter>Category!=LiveIntegration&amp;Category!=Integration&amp;Category!=Performance&amp;Category!=Simulations&amp;Category!=Slow&amp;Category!=Benchmark&amp;Category!=Stress</TestCaseFilter>
  </RunConfiguration>
  <xunit>
    <MaxParallelThreads>0</MaxParallelThreads>
  </xunit>
</RunSettings>

